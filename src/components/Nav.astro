---
import { base } from '../utils/base.js';

const currentPath = Astro.url.pathname.replace(/\/$/, '');

const links = [
  { href: `${base}/en/`, label: 'Home' },
  { href: `${base}/en/about`, label: 'About' },
  { href: `${base}/en/case-study-torino`, label: 'Relocation Suitability' },
  { href: `${base}/en/case-study-worldbuilding`, label: 'World-building' },
  { href: `${base}/en/contact`, label: 'Contact' },
];

function isActive(href) {
  const normalizedHref = href.replace(/\/$/, '');
  const isHome = normalizedHref === `${base}/en`;
  if (isHome) return currentPath === normalizedHref;
  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
}
---
<nav class="site-nav">
  {links.map((link) => (
    <a href={link.href} aria-current={isActive(link.href) ? 'page' : undefined}>
      {link.label}
    </a>
  ))}
</nav>

<style>
  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    padding: 1rem 1.5rem;
    background: var(--color-ink-light);
  }
  .site-nav a {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: normal;
    color: var(--color-paper);
    text-decoration: none;
    padding: 0.4rem 0.1rem;
    border-bottom: 2px solid transparent;
  }
  .site-nav a:hover,
  .site-nav a:focus-visible {
    color: var(--color-brass);
  }
  .site-nav a[aria-current='page'] {
    color: var(--color-brass);
    border-bottom-color: var(--color-brass);
  }
</style>