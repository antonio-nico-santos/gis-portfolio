---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { base } from '../../utils/base.js';

const caseStudies = [ 
  {
    title: 'Torino Urban Suitability', slug: 'torino'
  },
  {
    title: 'World-building GDR', slug: 'worldbuilding'
  }
];
---
<BaseLayout title="Nico Antonio - GIS Portfolio">
  <section class="hero">
    <h1>Home EN - placeholder</h1>
    <p>[Intro breve: chi sei, in 1-2 frasi tecniche]</p>
  </section>

  <section class="case-studies-preview">
    {caseStudies.map((cs) => (
      <article>
        <h2>{cs.title}</h2>
        <a href={`${base}/en/case-study-${cs.slug}/`}>View case study →</a>
      </article>
    ))}
  </section>

  <section class="cta">
    <a href={`${base}/en/contact`}>Get in touch →</a>
  </section>
</BaseLayout>