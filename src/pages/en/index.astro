  <section class="hero">
    <h1>Home EN - placeholder</h1>
    <p>[Intro breve: chi sei, in 1-2 frasi tecniche]</p>
  </section>

  <section class="case-studies-preview">
    <article>
      <h2>Torino Urban Suitability</h2>
      <a href={`${base}/en/case-study-torino/`}>View case study →</a>
    </article>
    <article>
      <h2>World-building GDR</h2>
      <a href={`${base}/en/case-study-worldbuilding/`}>View case study →</a>
    </article>
  </section>

  <section class="cta">
    <a href={`${base}/en/contact`}>Get in touch →</a>
  </section>
</BaseLayout>