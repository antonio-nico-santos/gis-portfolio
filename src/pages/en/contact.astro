---
import BaseLayout from '../../layouts/BaseLayout.astro';

// TODO(Nico): replace these once the real values/links exist.
const EMAIL = 'antonio.nico.santos@gmail.com';
const LINKEDIN_URL = 'https://www.linkedin.com/in/nico-antonio-santos';
const GITHUB_URL = 'https://github.com/antonio-nico-santos';
const CV_EN_URL = ''; // TODO: paste Drive share link once the English CV is exported from Europass
const CV_IT_URL = 'https://drive.google.com/file/d/18QL3LlNZYUdkSmgLYQwc2HPu2eDMmeiy/view?usp=sharing';

const contacts = [
  { label: 'Email', value: EMAIL, href: `mailto:${EMAIL}` },
  { label: 'LinkedIn', value: 'Antonio Augusto Santos', href: LINKEDIN_URL },
  { label: 'GitHub', value: 'antonio-nico-santos', href: GITHUB_URL },
];

const cvs = [
  { label: 'CV — English', href: CV_EN_URL },
  { label: 'CV — Italiano', href: CV_IT_URL },
];
---

<BaseLayout title="Contact - Nico Antonio">
  <div class="page-container">
    <section class="contact-hero">
      <h1>Contact</h1>
      <p class="lead">Get in touch, or download the CV.</p>
    </section>

    <section class="contact-block">
      {contacts.map((c) => (
        <div class="contact-row">
          <span class="contact-label">{c.label}</span>
          {c.href ? (
            <a href={c.href} target={c.href.startsWith('mailto:') ? undefined : '_blank'} rel="noopener">{c.value}</a>
          ) : (
            <span class="contact-pending">coming soon</span>
          )}
        </div>
      ))}
    </section>

    <section class="contact-block">
      <h2>Download CV</h2>
      {cvs.map((cv) => (
        <div class="contact-row">
          <span class="contact-label">{cv.label}</span>
          {cv.href ? (
            <a href={cv.href} target="_blank" rel="noopener">Download (Drive) →</a>
          ) : (
            <span class="contact-pending">coming soon</span>
          )}
        </div>
      ))}
    </section>
  </div>
</BaseLayout>

<style>
  .contact-hero {
    max-width: 42rem;
    margin-bottom: 2rem;
  }
  .contact-hero h1 {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 600;
    color: var(--color-paper);
    margin: 0 0 0.75rem;
  }
  .lead {
    font-family: var(--font-body);
    font-size: 1.1rem;
    color: var(--color-text-muted-2);
    line-height: 1.65;
    margin: 0;
  }
  .contact-block {
    max-width: 32rem;
    background: var(--color-ink-light);
    border-radius: 8px;
    padding: 0.5rem 1.4rem;
    margin-bottom: 1.5rem;
  }
  .contact-block h2 {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-brass);
    margin: 1rem 0 0.25rem;
  }
  .contact-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    padding: 0.85rem 0;
    border-bottom: 1px solid rgba(198, 146, 20, 0.15);
  }
  .contact-row:last-child {
    border-bottom: none;
  }
  .contact-label {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    letter-spacing: 0.04em;
  }
  .contact-row a {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-brass);
    text-decoration: none;
  }
  .contact-row a:hover {
    text-decoration: underline;
  }
  .contact-pending {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
